{
  "name": "ai-assistant-pro",
  "version": "2.0.0",
  "description": "AI Assistant Pro — Telegram Bot with Smart Routing, Vector Memory, and Cloud/Local LLM inference",
  "main": "src/bot.ts",
  "scripts": {
    "start": "node --loader ts-node/esm src/bot.ts",
    "dev": "nodemon --exec \"node --loader ts-node/esm\" src/bot.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml,sh}\"",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:reload": "npm run docker:down && npm run docker:build && npm run docker:up",
    "whisper:install": "git clone https://github.com/ggerganov/whisper.cpp .whisper && cd .whisper && make -j",
    "whisper:model": "cd .whisper && bash models/download-ggml-model.sh large-v3",
    "whisper:start": ".whisper/build/bin/whisper-server -m .whisper/models/ggml-large-v3.bin --port 8080 --host 0.0.0.0",
    "whisper:stop": "pkill -f whisper-server || true",
    "whisper:setup": "npm run whisper:install && npm run whisper:model",
    "dev:full": "npm run whisper:start & sleep 2 && npm run docker:up && npm run docker:logs"
  },
  "keywords": [
    "ai",
    "telegram",
    "llm",
    "ollama",
    "deepseek",
    "vector-memory"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1039.0",
    "@lancedb/lancedb": "^0.17.0",
    "@mariozechner/pi-coding-agent": "^0.70.2",
    "croner": "^10.0.1",
    "dotenv": "^17.4.2",
    "googleapis": "^171.4.0",
    "grammy": "^1.38.1",
    "js-tiktoken": "^1.0.19",
    "markdown-it": "^14.1.1",
    "miio": "^0.15.6",
    "nodemon": "^3.1.14",
    "tar-stream": "^3.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "vitest": "^4.1.5"
  }
}
